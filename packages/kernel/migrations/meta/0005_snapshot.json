      "checkConstraints": {
        "audit_events_id_check": {
          "name": "audit_events_id_check",
          "value": "length(\"audit_events\".\"id\") = 32 AND substr(\"audit_events\".\"id\", 1, 6) = 'audit_' AND substr(\"audit_events\".\"id\", 7, 1) GLOB '[0-7]' AND substr(\"audit_events\".\"id\", 7) NOT GLOB '*[^0123456789abcdefghjkmnpqrstvwxyz]*'"
        },
        "audit_events_actor_check": {
          "name": "audit_events_actor_check",
          "value": "(\"audit_events\".\"actor_kind\" = 'staff' AND \"audit_events\".\"actor_id\" IS NOT NULL AND \"audit_events\".\"staff_role\" IS NOT NULL) OR (\"audit_events\".\"actor_kind\" <> 'staff' AND \"audit_events\".\"staff_role\" IS NULL)"
        },
        "audit_events_actor_kind_check": {
          "name": "audit_events_actor_kind_check",
          "value": "\"audit_events\".\"actor_kind\" IN ('system', 'staff', 'customer', 'provider')"
        },
        "audit_events_staff_actor_id_check": {
          "name": "audit_events_staff_actor_id_check",
          "value": "\"audit_events\".\"actor_kind\" <> 'staff' OR (length(\"audit_events\".\"actor_id\") = 32 AND substr(\"audit_events\".\"actor_id\", 1, 6) = 'staff_' AND substr(\"audit_events\".\"actor_id\", 7, 1) GLOB '[0-7]' AND substr(\"audit_events\".\"actor_id\", 7) NOT GLOB '*[^0123456789abcdefghjkmnpqrstvwxyz]*')"
        },
        "audit_events_staff_role_check": {
          "name": "audit_events_staff_role_check",
          "value": "\"audit_events\".\"staff_role\" IS NULL OR \"audit_events\".\"staff_role\" IN ('owner', 'manager', 'staff')"
        },
        "audit_events_source_channel_check": {
          "name": "audit_events_source_channel_check",
          "value": "\"audit_events\".\"source_channel\" IN ('admin', 'storefront', 'provider_callback', 'workflow', 'telegram', 'provisioning')"
        },
        "audit_events_outcome_check": {
          "name": "audit_events_outcome_check",
          "value": "\"audit_events\".\"outcome\" IN ('accepted', 'rejected')"
        },
        "audit_events_correlation_length_check": {
          "name": "audit_events_correlation_length_check",
          "value": "length(\"audit_events\".\"command_correlation_id\") BETWEEN 1 AND 64"
        },
        "audit_events_metadata_check": {
          "name": "audit_events_metadata_check",
          "value": "\"audit_events\".\"metadata_json\" IS NULL OR (json_valid(\"audit_events\".\"metadata_json\") AND length(\"audit_events\".\"metadata_json\") <= 2048)"
        },
        "audit_events_fact_length_check": {
          "name": "audit_events_fact_length_check",
          "value": "length(\"audit_events\".\"action\") BETWEEN 1 AND 64 AND length(\"audit_events\".\"entity_kind\") BETWEEN 1 AND 64 AND length(\"audit_events\".\"entity_id\") BETWEEN 1 AND 128"
        }
      }
    },
