---
import { env } from "cloudflare:workers";
import { LivePurchase } from "@/components/prototypes/cache-proof/LivePurchase";
import { LiveSearch } from "@/components/prototypes/cache-proof/LiveSearch";
import ServerAvailability from "@/components/prototypes/cache-proof/ServerAvailability.astro";

interface ProductRow {
  id: string;
  slug: string;
  name: string;
  description: string;
  price_mnt: number;
  catalog_version: number;
}

interface VariantRow {
  id: string;
  label: string;
}

const product = await env.DB.prepare(
  "SELECT id, slug, name, description, price_mnt, catalog_version FROM cache_proof_products WHERE slug = ?",
)
  .bind(Astro.params.slug)
  .first<ProductRow>();

if (!product) return Astro.redirect("/prototype/products/nomad-cup", 302);

const variants = await env.DB.prepare(
  "SELECT id, label FROM cache_proof_variants WHERE product_id = ? ORDER BY position",
)
  .bind(product.id)
  .all<VariantRow>();
const canonical = new URL(`/prototype/products/${product.slug}`, Astro.url.origin).href;
const structuredProduct = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: product.description,
  offers: {
    "@type": "Offer",
    priceCurrency: "MNT",
    price: product.price_mnt,
    url: canonical,
  },
};
---

<!doctype html>
<html lang="mn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={product.description} />
    <link rel="canonical" href={canonical} />
    <title>{product.name} · Cached SSR proof</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredProduct)} is:inline />
  </head>
  <body>
    <header>
      <a class="proof-mark" href="/prototype/products/nomad-cup">WF25</a>
      <span>Cached SSR boundary</span>
      <small>catalog v{product.catalog_version}</small>
    </header>
    <main>
      <nav aria-label="Breadcrumb"><a href="/">Prototype</a><span>/</span><span>{product.name}</span></nav>
      <div class="proof-layout">
        <article>
          <p class="proof-eyebrow">Cached public HTML</p>
          <h1>{product.name}</h1>
          <p class="proof-price">{new Intl.NumberFormat("mn-MN").format(product.price_mnt)} ₮-с</p>
          <p class="proof-description">{product.description}</p>
          <dl>
            <div><dt>HTML-д байгаа</dt><dd>Нэр, тайлбар, эхлэх үнэ, хувилбарын нэр</dd></div>
            <div><dt>HTML-д байхгүй</dt><dd>Үлдэгдэл, захиалах боломж, checkout шийдвэр</dd></div>
          </dl>
        </article>
        <LivePurchase variants={variants.results} client:load />
      </div>
      <div class="proof-comparison">
        <ServerAvailability variantId={variants.results[0]?.id ?? ""} server:defer>
          <section class="proof-server" slot="fallback" aria-live="polite">
            <p class="proof-eyebrow">Astro server island comparison</p>
            <h2>Шинэ үлдэгдлийг шалгаж байна…</h2>
          </section>
        </ServerAvailability>
        <LiveSearch client:load />
      </div>
    </main>
  </body>
</html>

<style is:global>
  :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, sans-serif; background: oklch(0.965 0.012 82); color: oklch(0.22 0.025 58); }
  * { box-sizing: border-box; }
  body { margin: 0; min-height: 100vh; }
  header { display: flex; align-items: baseline; gap: 1rem; padding: 1rem clamp(1rem, 4vw, 4rem); border-bottom: 1px solid oklch(0.82 0.025 75); }
  header small { margin-left: auto; color: oklch(0.48 0.025 58); }
  .proof-mark { color: oklch(0.38 0.12 38); font-weight: 800; letter-spacing: .08em; text-decoration: none; }
  main { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; padding: clamp(1.25rem, 5vw, 4.5rem) 0; }
  nav { display: flex; gap: .6rem; margin-bottom: 3rem; color: oklch(0.48 0.025 58); font-size: .875rem; }
  nav a { color: inherit; }
  .proof-layout { display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(280px, .65fr); gap: clamp(2rem, 6vw, 6rem); align-items: start; }
  h1 { max-width: 10ch; margin: .25rem 0 .75rem; font-family: Georgia, serif; font-size: clamp(3rem, 8vw, 7rem); font-weight: 500; line-height: .94; letter-spacing: -.045em; }
  h2 { margin: .25rem 0 1.25rem; font-size: 1.35rem; }
  .proof-eyebrow { margin: 0; color: oklch(0.42 0.1 38); font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
  .proof-price { margin: 1.75rem 0 .75rem; font-size: 1.5rem; font-weight: 700; }
  .proof-description { max-width: 58ch; color: oklch(0.4 0.025 58); line-height: 1.7; }
  dl { margin-top: 3rem; border-top: 1px solid oklch(0.82 0.025 75); }
  dl div { display: grid; grid-template-columns: 9rem 1fr; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid oklch(0.82 0.025 75); }
  dt { font-weight: 700; } dd { margin: 0; color: oklch(0.43 0.025 58); }
  .proof-purchase, .proof-server, .proof-search { padding: 1.5rem; border: 1px solid oklch(0.78 0.035 75); background: oklch(0.985 0.008 82); box-shadow: 0 18px 45px oklch(0.32 0.025 58 / .08); }
  label { display: block; margin: 1rem 0 .4rem; font-size: .8rem; font-weight: 700; }
  input, select, button { width: 100%; min-height: 2.8rem; border: 1px solid oklch(0.7 0.035 70); border-radius: .35rem; background: oklch(0.99 0.005 82); color: inherit; font: inherit; }
  input, select { padding: .65rem .75rem; }
  button { margin-top: 1rem; border-color: oklch(0.33 0.09 38); background: oklch(0.33 0.09 38); color: oklch(0.97 0.008 82); font-weight: 750; cursor: pointer; transition: transform 120ms cubic-bezier(.22,1,.36,1), opacity 120ms ease; }
  button:active:not(:disabled) { transform: scale(.985); }
  button:disabled { cursor: not-allowed; opacity: .42; }
  input:focus-visible, select:focus-visible, button:focus-visible, a:focus-visible { outline: 3px solid oklch(0.68 0.15 62); outline-offset: 3px; }
  .proof-live { min-height: 2.8rem; margin: 1rem 0; padding: .8rem; border-radius: .35rem; background: oklch(0.93 0.028 79); font-size: .9rem; line-height: 1.4; }
  .proof-result { min-height: 2.5rem; color: oklch(0.4 0.08 38); font-size: .86rem; line-height: 1.45; }
  .proof-comparison { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 5rem; }
  .proof-server small { display: block; color: oklch(0.48 0.025 58); line-height: 1.5; }
  .proof-search ul { margin: 1rem 0 0; padding: 0; list-style: none; }
  .proof-search li { display: flex; justify-content: space-between; gap: 1rem; padding: .7rem 0; border-top: 1px solid oklch(0.86 0.02 75); }
  .proof-search a { color: oklch(0.32 0.08 38); font-weight: 700; }
  @media (max-width: 760px) { .proof-layout, .proof-comparison { grid-template-columns: 1fr; } h1 { font-size: clamp(3.5rem, 17vw, 6rem); } nav { margin-bottom: 2rem; } dl div { grid-template-columns: 1fr; gap: .3rem; } }
  @media (prefers-reduced-motion: reduce) { button { transition: none; } }
</style>
