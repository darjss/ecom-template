---
import { UiFormFoundationPrototype } from "@/components/prototypes/ui-form-foundation/UiFormFoundationPrototype";
import "@/styles/global.css";

if (!import.meta.env.DEV) {
  return new Response("Not found", {
    status: 404,
    headers: { "content-type": "text/plain; charset=utf-8" },
  });
}
---

<!doctype html>
<html lang="mn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23171717'/%3E%3Ctext x='16' y='22' text-anchor='middle' font-family='sans-serif' font-size='17' fill='%23fafafa'%3EM%3C/text%3E%3C/svg%3E"
    />
    <meta
      name="description"
      content="Disposable browser prototype for the shared merchant form foundation."
    />
    <title>UI form foundation prototype</title>
  </head>
  <body>
    <UiFormFoundationPrototype client:only="solid-js" />
  </body>
</html>
