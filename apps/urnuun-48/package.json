{
  "name": "@shops/urnuun-48",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:direct",
    "dev:direct": "astro dev --host 127.0.0.1 --port ${PORT:-4321}",
    "build": "astro build",
    "preview": "pnpm --dir ../.. store:delivery preview --store urnuun-48",
    "preview:direct": "wrangler dev --config dist/server/wrangler.json --ip 127.0.0.1 --port ${PORT} --upstream-protocol https --persist-to .wrangler/state",
    "bindings:generate": "wrangler types worker-configuration.d.ts --config wrangler.jsonc --env-file=.bindings.vars",
    "db:migrate:local": "wrangler d1 migrations apply urnuun-48-db --local --config wrangler.jsonc"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.1.1",
    "@astrojs/solid-js": "7.0.1",
    "@ecom/admin": "workspace:*",
    "@ecom/api": "workspace:*",
    "@ecom/integrations": "workspace:*",
    "@ecom/storefront": "workspace:*",
    "@ecom/ui": "workspace:*",
    "@tailwindcss/vite": "4.3.2",
    "astro": "7.0.6",
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "6.7.3",
    "@astrojs/check": "0.9.9",
    "eslint": "9.39.2",
    "eslint-plugin-astro": "1.6.0",
    "typescript": "npm:@typescript/typescript6@6.0.2"
  }
}
