---
import { PersonalizationControls, ProductVariantSelector } from "@ecom/storefront";
import { applyPublicHtmlCache } from "@ecom/storefront/cache";
import StoreLayout from "../../layouts/StoreLayout.astro";
import { storefront } from "../../api";

export const prerender = false;
const product = await storefront.readPublishedProduct(Astro.params.slug ?? "");
if (!product) {
  return new Response("Бүтээгдэхүүн олдсонгүй", {
    status: 404,
    headers: { "cache-control": "private, no-store" },
  });
}
const personalizations = await storefront.readPersonalizations(product.id);
applyPublicHtmlCache(Astro.response.headers, ["store-shell", "catalog", `product:${product.id}`]);
const imageWidths = [320, 640, 960, 1280];
const imageSrcset = (mediaAssetId: string, format: "avif" | "webp") =>
  imageWidths.map((width) => `/media/${mediaAssetId}/${width}.${format} ${width}w`).join(", ");
---
<StoreLayout title={`${product.name} · Өрнүүн 48`} description={product.description || product.name}>
  <p class="demo-notice">Энэ бол зохиомол жишиг дэлгүүр. Бодит захиалга хүлээн авахгүй.</p>
  <header class="site-header">
    <a class="wordmark" href="/" transition:name="wordmark"><b>48</b><span>Өрнүүн</span></a>
    <nav aria-label="Үндсэн цэс"><a href="/">Дэлгүүр</a><a href="/story">Бидний тухай</a></nav>
    <a class="admin-link" href="/admin">Удирдлага</a>
  </header>
  <main id="content">
    <article class="featured" aria-labelledby="product-title">
      <div class="product-visual">
        <span class="bay-number">Каталог</span>
        {product.images.length === 0
          ? <div class="grid aspect-square place-items-center bg-(--surface) p-6 text-center text-(--muted)">Зураг оруулаагүй байна</div>
          : <div class="grid gap-3 sm:grid-cols-2">
              {product.images.map((image, index) => (
                <picture class={index === 0 ? "sm:col-span-2" : undefined}>
                  <source
                    type="image/avif"
                    srcset={imageSrcset(image.mediaAssetId, "avif")}
                    sizes="(max-width: 767px) 100vw, 50vw"
                  />
                  <img
                    class="aspect-square w-full object-cover"
                    src={`/media/${image.mediaAssetId}/960.webp`}
                    srcset={imageSrcset(image.mediaAssetId, "webp")}
                    sizes="(max-width: 767px) 100vw, 50vw"
                    alt={image.altText}
                    width="960"
                    height="960"
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : "auto"}
                    decoding="async"
                  />
                </picture>
              ))}
            </div>}
      </div>
      <div class="product-copy">
        <p class="kicker">Нийтлэгдсэн бүтээгдэхүүн</p>
        <h1 id="product-title">{product.name}</h1>
        {product.description && <p>{product.description}</p>}
        <ProductVariantSelector product={product} client:load />
        <PersonalizationControls definitions={personalizations} client:load />
      </div>
    </article>
  </main>
</StoreLayout>
