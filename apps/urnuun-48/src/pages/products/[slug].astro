---
import { PurchaseIsland } from "@ecom/storefront";
import { applyPublicHtmlCache, productCacheTag } from "@ecom/storefront/cache";
import OrderingNotices from "../../components/OrderingNotices.astro";
import PurchaseFallback from "../../components/PurchaseFallback.astro";
import StoreShell from "../../components/StoreShell.astro";
import StoreLayout from "../../layouts/StoreLayout.astro";
import { storefront } from "../../api";

export const prerender = false;
const product = await storefront.readPublishedProduct(Astro.params.slug ?? "");
if (!product) {
  return new Response("Бүтээгдэхүүн олдсонгүй", {
    status: 404,
    headers: { "cache-control": "private, no-store" },
  });
}
const [personalizations, shell, orderingNotices] = await Promise.all([
  storefront.readPersonalizations(product.id),
  storefront.readShell(),
  storefront.readOrderingNotices(),
]);
const storeName = shell.identity?.displayName ?? "Өрнүүн 48";
applyPublicHtmlCache(Astro.response.headers, [
  "store-shell",
  "catalog",
  productCacheTag(product.id),
]);
const selectedCatalogVariant = product.variants[0];
const availableValueIds = new Set(
  product.variants.flatMap((variant) => variant.optionValues.map(({ valueId }) => valueId)),
);
const fallbackOptionGroups = product.optionGroups.map((group) => ({
  ...group,
  values: group.values.filter(({ id }) => availableValueIds.has(id)),
}));
const imageWidths = [320, 640, 960, 1280];
const imageSrcset = (mediaAssetId: string, format: "avif" | "webp") =>
  imageWidths.map((width) => `/media/${mediaAssetId}/${width}.${format} ${width}w`).join(", ");
---
<StoreLayout title={`${product.name} · ${storeName}`} description={product.description || product.name}>
  <p class="demo-notice">Энэ бол зохиомол жишиг дэлгүүр. Бодит захиалга хүлээн авахгүй.</p>
  <StoreShell shell={shell} currentPath={Astro.url.pathname} fallbackName={storeName}>
    <main id="content" class="product-page">
      <nav class="product-breadcrumb" aria-label="Байршил">
        <a href="/">Дэлгүүр</a><span aria-hidden="true">/</span><span aria-current="page">{product.name}</span>
      </nav>
      <article class="product-detail" aria-labelledby="product-title">
        <div class="product-gallery">
          <span class="product-gallery__marker">Тавиур · бүтээгдэхүүн</span>
          {product.images.length === 0
            ? <div class="product-gallery__placeholder"><b>48</b><span>Зураг оруулаагүй байна</span></div>
            : <div class="product-gallery__grid">
                {product.images.map((image, index) => (
                  <picture class={index === 0 ? "product-gallery__primary" : "product-gallery__secondary"}>
                    <source
                      type="image/avif"
                      srcset={imageSrcset(image.mediaAssetId, "avif")}
                      sizes="(max-width: 767px) 100vw, 58vw"
                    />
                    <img
                      src={`/media/${image.mediaAssetId}/960.webp`}
                      srcset={imageSrcset(image.mediaAssetId, "webp")}
                      sizes="(max-width: 767px) 100vw, 58vw"
                      alt={image.altText}
                      width="960"
                      height="960"
                      loading={index === 0 ? "eager" : "lazy"}
                      fetchpriority={index === 0 ? "high" : "auto"}
                      decoding="async"
                    />
                  </picture>
                ))}
              </div>}
        </div>
        <div class="product-purchase">
          <header class="product-purchase__heading">
            <span>Өрнүүн 48 · өдөр тутмын сонголт</span>
            <h1 id="product-title">{product.name}</h1>
            {product.description && <p>{product.description}</p>}
          </header>
          <section class="purchase-boundary" aria-label="Худалдан авах хэсэг">
            {selectedCatalogVariant && (
              <PurchaseFallback
                priceMnt={selectedCatalogVariant.priceMnt}
                sku={selectedCatalogVariant.sku}
                optionGroups={fallbackOptionGroups}
                personalizations={personalizations}
              />
            )}
            <PurchaseIsland
              kind="product"
              product={product}
              personalizations={personalizations}
              storageKey="cart:urnuun-48:v1"
              client:only="solid-js"
            />
          </section>
        </div>
      </article>
      <aside class="product-trust" aria-label="Худалдан авалтын мэдээлэл">
        <div><span>Үнэ</span><strong>Сонголт бүрээр шинэчилнэ</strong></div>
        <div><span>Төлбөр</span><strong>Банкны шилжүүлэг</strong></div>
        <div><span>Хүргэлт</span><strong>Улаанбаатар хотод</strong></div>
      </aside>
      <OrderingNotices document={orderingNotices} placement="product" />
    </main>
  </StoreShell>
</StoreLayout>
