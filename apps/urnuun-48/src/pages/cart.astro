---
import { CartIsland } from "@ecom/storefront";
import { applyPublicHtmlCache } from "@ecom/storefront/cache";
import StoreShell from "../components/StoreShell.astro";
import StoreLayout from "../layouts/StoreLayout.astro";
import { storefront } from "../api";

type CartCatalogEntry = import("@ecom/storefront").CartCatalogEntry;

export const prerender = false;
const [shell, catalogItems] = await Promise.all([
  storefront.readShell(),
  storefront.listPublishedCatalogItems(),
]);
const [products, bundles] = await Promise.all([
  Promise.all(
    catalogItems
      .filter(({ kind }) => kind === "product")
      .map(({ slug }) => storefront.readPublishedProduct(slug)),
  ),
  Promise.all(
    catalogItems
      .filter(({ kind }) => kind === "bundle")
      .map(({ slug }) => storefront.readPublishedBundle(slug)),
  ),
]);
const catalog: CartCatalogEntry[] = [
  ...products.flatMap((product) =>
    product
      ? product.variants.map((variant) => ({
          kind: "variant" as const,
          id: variant.id,
          name: product.name,
          href: `/products/${product.slug}`,
          sku: variant.sku,
          optionLabel:
            variant.optionValues.map(({ valueLabel }) => valueLabel).join(" · ") || "Үндсэн сонголт",
          priceMnt: variant.priceMnt,
          image: variant.image ?? product.images.at(0) ?? null,
        }))
      : [],
  ),
  ...bundles.flatMap((bundle) =>
    bundle
      ? [
          {
            kind: "bundle" as const,
            id: bundle.id,
            name: bundle.name,
            href: `/bundles/${bundle.slug}`,
            sku: bundle.sku,
            optionLabel: "Багц",
            priceMnt: bundle.priceMnt,
            image: bundle.images.at(0) ?? null,
          },
        ]
      : [],
  ),
];
const storeName = shell.identity?.displayName ?? "Өрнүүн 48";
applyPublicHtmlCache(Astro.response.headers, ["store-shell", "catalog"]);
---
<StoreLayout title={`Сагс · ${storeName}`} description={`${storeName} дэлгүүрийн сагс`}>
  <p class="demo-notice">Энэ бол зохиомол жишиг дэлгүүр. Бодит захиалга хүлээн авахгүй.</p>
  <StoreShell shell={shell} currentPath={Astro.url.pathname} fallbackName={storeName}>
    <main id="content" class="mx-auto w-full max-w-6xl px-5 py-10 sm:px-8 sm:py-16">
      <header class="mb-8 grid gap-4 border-b border-black/15 pb-8 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
        <div>
          <p class="mb-3 text-sm font-bold text-(--accent)">Өрнүүн 48 · худалдан авалт</p>
          <h1 class="m-0 text-4xl font-extrabold tracking-[-0.035em] text-balance sm:text-6xl">Сагс</h1>
          <p class="mt-4 mb-0 max-w-xl text-(--muted)">
            Сонголтоо шалгаад одоогийн үнэ, үлдэгдэл, хүргэлтийн дүнг серверээс баталгаажуулна.
          </p>
        </div>
        <a
          class="font-bold underline decoration-transparent underline-offset-4 hover:decoration-current focus-visible:outline-3 focus-visible:outline-offset-3 focus-visible:outline-(--focus)"
          href="/#featured"
        >
          Үргэлжлүүлэн сонгох
        </a>
      </header>
      <CartIsland storageKey="cart:urnuun-48:v1" catalog={catalog} client:only="solid-js" />
    </main>
  </StoreShell>
</StoreLayout>
