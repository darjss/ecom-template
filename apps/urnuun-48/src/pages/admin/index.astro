---
import { AdminApp } from "@ecom/admin";
import { readStaffPresentationRole } from "@ecom/api";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { storeDefinition } from "../../profile/definition";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");
const role = readStaffPresentationRole(Astro.request.headers);
---
<AdminLayout title="Өрнүүн 48 · Удирдлага">
  <AdminApp role={role} storeName={storeDefinition.profile.name} client:only="solid-js" />
</AdminLayout>
