---
import { AdminManagement } from "@ecom/admin";
import { readStaffPresentationRole } from "@ecom/api";
import AdminShell from "../../components/AdminShell.astro";
import { storeDefinition } from "../../profile/definition";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");
const role = readStaffPresentationRole(Astro.request.headers);
---
<AdminShell
  title="Дэлгүүр"
  description="Каталог, контент, бүлэглэл, хөнгөлөлт болон ажилтны эрхийн одоогийн удирдлага."
  active="management"
>
  <AdminManagement
    role={role}
    store={storeDefinition.profile.slug}
    client:only="solid-js"
  />
</AdminShell>
