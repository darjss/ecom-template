---
import { OrderStatusIsland } from "@ecom/storefront";
import StoreShell from "../../../components/StoreShell.astro";
import StoreLayout from "../../../layouts/StoreLayout.astro";
import { storefront } from "../../../api";

export const prerender = false;
Astro.response.headers.set("cache-control", "private, no-store");
Astro.response.headers.set("referrer-policy", "no-referrer");
Astro.response.headers.set("x-robots-tag", "noindex, nofollow");
const token = Astro.params.token ?? "";
if (!/^[a-f0-9]{64}$/.test(token)) {
  Astro.response.status = 404;
}
const [summary, shell, homeContent] = await Promise.all([
  storefront.readSummary(),
  storefront.readShell(),
  storefront.readHomeCmsContent(),
]);
const storeName = shell.identity?.displayName ?? summary.storeName;
---
<StoreLayout title={`Захиалгын төлөв · ${storeName}`} description="Захиалгын төлбөр болон бэлтгэл, хүргэлтийн одоогийн төлөв" noindex>
  <StoreShell shell={{ ...shell, announcement: homeContent.announcement }} currentPath="" fallbackName={summary.storeName}>
    <main id="content" class="bg-(--surface) px-4 py-10 sm:px-6 sm:py-16">
      <div class="mx-auto w-full max-w-5xl">
        <header class="mb-8 grid items-end gap-5 border-b border-(--wood-dark) pb-7 sm:mb-10 sm:grid-cols-[minmax(0,1fr)_18rem]">
          <div>
            <p class="m-0 text-sm font-black text-(--accent)">{storeName} захиалга</p>
            <h1 class="m-0 mt-2 max-w-3xl text-4xl leading-[0.98] font-black tracking-[-0.035em] text-balance sm:text-6xl">
              Захиалгаа эндээс хянаарай
            </h1>
          </div>
          <p class="m-0 max-w-[36rem] text-pretty text-(--muted)">
            Төлбөр баталгаажсан эсэх, бараа бэлтгэл болон хүргэлтийн явцыг одоогийн байдлаар харуулна.
          </p>
        </header>
        <OrderStatusIsland token={token} client:only="solid-js" />
        <p class="m-0 mt-6 max-w-2xl text-sm text-(--muted)">
          Энэ холбоос таны нэг захиалгын мэдээллийг харуулдаг тул бусдад дамжуулахгүй хадгална уу.
        </p>
      </div>
    </main>
  </StoreShell>
</StoreLayout>
