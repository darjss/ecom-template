---
import { applyPublicHtmlCache } from "@ecom/storefront/cache";
import { CartIsland } from "@ecom/storefront/cart";
import StoreLayout from "../layouts/StoreLayout.astro";
import { backend } from "../backend";
import { storeDefinition } from "../profile/definition";

export const prerender = false;
applyPublicHtmlCache(Astro.response.headers, ["store-shell", "homepage", "catalog"]);
const summary = await backend.storefront.readSummary();
const featuredItem = storeDefinition.presentation.featuredItem;
---
<StoreLayout title={`${summary.storeName} · Өдөр тутмын сонголт`} description="Өрнүүн 48-ийн удаан эдэлгээтэй өдөр тутмын сонголтууд">
  <header class="site-header">
    <a class="wordmark" href="/" aria-current="page" transition:name="wordmark">Өрнүүн 48</a>
    <nav aria-label="Үндсэн цэс"><a aria-current="page" href="/">Дэлгүүр</a><a href="/story">Бидний тухай</a></nav>
    <a class="admin-link" href="/admin">Удирдлага</a>
  </header>
  <main id="content">
    <section class="hero">
      <div class="hero-copy">
        <p class="kicker">{summary.location}</p>
        <h1>Хотын хэмнэлд<br />удаан хэрэглэгдэх зүйлс.</h1>
        <p class="hero-note">Өдөр бүр барьж, өмсөж, гэртээ хэрэглэдэг зүйлсийг чанар болон хэрэгцээгээр нь сонгов.</p>
        <a class="text-link" href="#featured">Энэ долоо хоногийн сонголт</a>
      </div>
      <div class="hero-art" aria-hidden="true">
        <span>48</span>
        <div class="sun"></div>
      </div>
    </section>
    <section id="featured" class="featured" aria-labelledby="featured-title">
      <div class="product-visual" transition:name="featured-product">
        <div class="bag-shape" aria-hidden="true"><span>Ө48</span></div>
      </div>
      <div class="product-copy">
        <p class="kicker">Долоо хоногийн сонголт</p>
        <h2 id="featured-title">{featuredItem.title}</h2>
        <p>Зузаан хөвөн даавуу, мөрөнд эвтэйхэн урт бариул, хот доторх өдөр тутмын ачаанд таарсан хэмжээ.</p>
        <strong>{new Intl.NumberFormat("mn-MN").format(featuredItem.unitPriceMnt)} ₮</strong>
        <CartIsland
          {...featuredItem}
          storageKey={storeDefinition.cartStorageKey}
          client:only="solid-js"
        />
      </div>
    </section>
  </main>
  <footer><span>Өрнүүн 48</span><span>Өдөр бүр 10:00–21:00</span></footer>
</StoreLayout>
