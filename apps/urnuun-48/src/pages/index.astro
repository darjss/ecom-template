---
import { applyPublicHtmlCache } from "@ecom/storefront/cache";
import HomeContent from "../components/HomeContent.astro";
import StoreShell from "../components/StoreShell.astro";
import StoreLayout from "../layouts/StoreLayout.astro";
import { storefront } from "../api";

export const prerender = false;
applyPublicHtmlCache(Astro.response.headers, ["store-shell", "homepage", "catalog"]);
const [summary, shell, homeContent, catalogItems, groupings] = await Promise.all([
  storefront.readSummary(),
  storefront.readShell(),
  storefront.readHomeCmsContent(),
  storefront.listPublishedCatalogItems(),
  storefront.listPublishedGroupings(),
]);
const identity = shell.identity;
const storeName = identity?.displayName ?? summary.storeName;
---
<StoreLayout title={`${storeName} · Өдөр бүрийн хэрэгцээ`} description={identity?.summary ?? "Өрнүүн 48-ийн өдөр тутмын хүнс, гэр ахуй, жижиг бэлгийн сонголт"}>
  <p class="demo-notice">Энэ бол зохиомол жишиг дэлгүүр. Бодит захиалга хүлээн авахгүй.</p>
  <StoreShell shell={{ ...shell, announcement: homeContent.announcement }} currentPath="/" fallbackName={summary.storeName}>
    <HomeContent homepage={homeContent.homepage} shell={shell} catalogItems={catalogItems} groupings={groupings} />
  </StoreShell>
</StoreLayout>
