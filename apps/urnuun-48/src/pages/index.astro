---
import { applyPublicHtmlCache } from "@ecom/storefront/cache";
import { CustomerAuthIsland } from "@ecom/storefront";
import StoreLayout from "../layouts/StoreLayout.astro";
import { storefront } from "../api";

export const prerender = false;
applyPublicHtmlCache(Astro.response.headers, ["store-shell", "homepage", "catalog"]);
const summary = await storefront.readSummary();
const [identity, navigation, locations, policies, commerceSettings, products, groupings] = await Promise.all([
  storefront.readIdentity(),
  storefront.readNavigation(),
  storefront.readLocations(),
  storefront.readPolicies(),
  storefront.readCommerceSettings(),
  storefront.listPublishedProducts(),
  storefront.listPublishedGroupings(),
]);
const storeName = identity?.displayName ?? summary.storeName;
const locationById = new Map(locations?.locations.map((location) => [location.id, location]));
const policyById = new Map(policies?.policies.map((policy) => [policy.id, policy]));
const categoryById = new Map(groupings.categories.map((category) => [category.id, category]));
const collectionById = new Map(groupings.collections.map((collection) => [collection.id, collection]));
const productById = new Map(products.map((product) => [product.id, product]));
const destinationHref = (destination: typeof navigation extends undefined ? never : NonNullable<typeof navigation>["primary"][number]["destination"]) => {
  switch (destination.kind) {
    case "home": return "/";
    case "category": return categoryById.get(destination.id) ? `/categories/${categoryById.get(destination.id)?.slug}` : undefined;
    case "collection": return collectionById.get(destination.id) ? `/collections/${collectionById.get(destination.id)?.slug}` : undefined;
    case "catalog_item": return productById.get(destination.id) ? `/products/${productById.get(destination.id)?.slug}` : undefined;
    case "location": return locationById.has(destination.id) ? `/locations/${destination.id}` : undefined;
    case "policy": return policyById.get(destination.id) ? `/policies/${policyById.get(destination.id)?.kind}` : undefined;
    case "external": return destination.url;
  }
};
---
<StoreLayout title={`${storeName} · Өдөр бүрийн хэрэгцээ`} description={identity?.summary ?? "Өрнүүн 48-ийн өдөр тутмын хүнс, гэр ахуй, жижиг бэлгийн сонголт"}>
  <p class="demo-notice">Энэ бол зохиомол жишиг дэлгүүр. Бодит захиалга хүлээн авахгүй.</p>
  <header class="site-header">
    <a class="wordmark" href="/" aria-current="page" transition:name="wordmark"><b>48</b><span>{storeName}</span></a>
    <nav aria-label="Үндсэн цэс">{navigation?.primary.filter((item) => item.enabled).map((item) => { const href = destinationHref(item.destination); return href ? <a aria-current={item.destination.kind === "home" ? "page" : undefined} href={href}>{item.label}</a> : null; }) ?? <><a aria-current="page" href="/">Дэлгүүр</a><a href="/locations">Байршил</a></>}</nav>
    <a class="admin-link" href="/admin">Удирдлага</a>
  </header>
  <main id="content">
    <section class="pantry" aria-labelledby="pantry-title">
      <div class="pantry-beam">
        <span>Ө48 Өдөр</span><b>Тавиур 01 · өдөр тутмын нөөц</b><span>УБ · 09:00–21:00</span>
      </div>
      <div class="pantry-grid">
        <aside class="pantry-categories" aria-label="Бүтээгдэхүүний ангилал">
          <p>Тасалгаа</p>
          <ol>
            {groupings.categories.length === 0
              ? <li><span>—</span>Ангилал удахгүй нэмэгдэнэ</li>
              : groupings.categories.map((category, index) => <li><span>{String(index + 1).padStart(2, "0")}</span><a href={`/categories/${category.slug}`}>{category.name}</a></li>)}
          </ol>
        </aside>
        <div class="pantry-copy">
          <p class="kicker">Өдөр бүрийн хэрэгцээг цэгцтэй</p>
          <h1 id="pantry-title">Гэрийн<br /><span>тавиур.</span></h1>
          <p>{identity?.tagline ?? "Хүнс, цэвэрлэгээ, жижиг бэлгийг нэг тавиураас ойлгомжтой сонгоорой."}</p>
          <a href="#featured">Тавиур үзэх</a>
        </div>
        <div class="pantry-image">
          <img src="/media/hero-pantry.webp" alt="Хүнс, гэр ахуйн бүтээгдэхүүн өрсөн Өрнүүн 48-ын цайвар модон тавиур" width="1000" height="1000" fetchpriority="high" />
          <div class="shelf-marker" aria-hidden="true"><b>48</b><span>гэрийн нөөц</span></div>
        </div>
        <article class="bundle-bay">
          <img src="/media/b01-cleaning-bundle.webp" alt="Угаалгын нунтаг болон аяга таваг угаагчийн цэвэрлэгээний хослол" width="1000" height="1000" loading="lazy" />
          <p>Тасалгаа 05</p><h2>Цэвэрлэгээний хослол</h2><span>Каталогоос сонгоорой</span>
        </article>
        <div class="delivery-bay"><span>{new Intl.NumberFormat("mn-MN").format(commerceSettings?.freeDeliveryThresholdMnt ?? 120000)} ₮</span><strong>дээш хүргэлт үнэгүй</strong><small>{commerceSettings?.deliveryEnabled === false ? "Хүргэлт түр хаалттай" : "Улаанбаатар хотод"}</small></div>
      </div>
      <div class="pantry-plinth"><span>01 Хүнс</span><span>02 Гэр ахуй</span><span>03 Жижиг бэлэг</span><b>ӨРНҮҮН / 48</b></div>
    </section>
    <section id="featured" class="featured" aria-labelledby="featured-title">
      <div class="product-copy">
        <p class="kicker">Нийтлэгдсэн каталог</p>
        <h2 id="featured-title">Өдөр тутмын сонголт</h2>
        <p>Үнэ нь бүхэл төгрөгөөр харагдана. Худалдан авах боломжийг захиалгын өмнө шинээр шалгана.</p>
      </div>
      <div class="product-copy">
        {groupings.collections.length > 0 && <nav class="mb-6 flex flex-wrap gap-3" aria-label="Цуглуулга"><span class="font-bold">Цуглуулга:</span>{groupings.collections.map((collection) => <a href={`/collections/${collection.slug}`}>{collection.name}</a>)}</nav>}
        {products.length === 0 ? <p>Одоогоор нийтлэгдсэн бүтээгдэхүүн алга.</p> : <ul class="catalog-list">{products.map((product) => <li><a href={`/products/${product.slug}`}><strong>{product.name}</strong><span>{new Intl.NumberFormat("mn-MN").format(product.priceMnt)} ₮</span></a></li>)}</ul>}
      </div>
    </section>
    <section class="customer-auth" aria-labelledby="customer-auth-title">
      <div>
        <h2 id="customer-auth-title">Захиалгын түүхээ хадгалах</h2>
        <p>Утасны дугаараа нэг удаагийн кодоор баталгаажуулбал энэ дэлгүүрийн захиалгуудаа дараа нь харж болно. Худалдан авалт хийхэд нэвтрэх шаардлагагүй.</p>
      </div>
      <CustomerAuthIsland client:only="solid-js" />
    </section>
  </main>
  <footer><span>{storeName}</span>{navigation?.footer.map((group) => <nav aria-label={group.label}>{group.items.filter((item) => item.enabled).map((item) => { const href = destinationHref(item.destination); return href ? <a href={href}>{item.label}</a> : null; })}</nav>)}<span>{locations?.locations.find((location) => location.active)?.address ?? summary.location}</span></footer>
</StoreLayout>
