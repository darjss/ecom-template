---
import { applyPublicHtmlCache } from "@ecom/storefront";
import StoreLayout from "../layouts/StoreLayout.astro";

applyPublicHtmlCache(Astro.response.headers, ["store-shell"]);
---
<StoreLayout title="Бидний тухай · Өрнүүн 48" description="Өрнүүн 48 дэлгүүрийн түүх">
  <header class="site-header">
    <a class="wordmark" href="/" transition:name="wordmark">Өрнүүн 48</a>
    <nav aria-label="Үндсэн цэс"><a href="/">Дэлгүүр</a><a aria-current="page" href="/story">Бидний тухай</a></nav>
    <a class="admin-link" href="/admin">Удирдлага</a>
  </header>
  <main id="content" class="story-page">
    <p class="kicker">Улаанбаатар · 2008 оноос</p>
    <h1>Өдөр тутмын хэрэгцээг ойроос, бодож сонгоно.</h1>
    <p>48-р дэлгүүрийн хажуу дахь жижиг лангуунаас эхэлсэн Өрнүүн өнөөдөр гэр бүл бүрт хэрэгтэй, удаан эдэлгээтэй барааг танилцуулдаг орон нутгийн дэлгүүр болжээ.</p>
    <a class="text-link" href="/">Сонголтоо үзэх</a>
  </main>
</StoreLayout>
