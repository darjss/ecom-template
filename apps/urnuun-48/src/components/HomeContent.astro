---
import type { StoreBackend } from "@ecom/api";
import { CustomerAuthIsland } from "@ecom/storefront";
import CatalogProductCard from "./CatalogProductCard.astro";

type Storefront = StoreBackend["storefront"];
type CatalogItems = Awaited<ReturnType<Storefront["listPublishedCatalogItems"]>>;
type Groupings = Awaited<ReturnType<Storefront["listPublishedGroupings"]>>;
type HomeCmsContent = Awaited<ReturnType<Storefront["readHomeCmsContent"]>>;
type Shell = Awaited<ReturnType<Storefront["readShell"]>>;
interface Props {
  homepage: HomeCmsContent["homepage"];
  shell: Shell;
  catalogItems: CatalogItems;
  groupings: Groupings;
}
const { homepage, shell, catalogItems, groupings } = Astro.props;
const commerceSettings = shell.commerceSettings;
const catalogById = new Map(catalogItems.map((item) => [item.id, item]));
const publishedProducts = catalogItems.filter(({ kind }) => kind === "product");
const featuredProducts = homepage
  ? homepage.featuredCatalogItemIds.flatMap((id) => {
      const item = catalogById.get(id);
      return item?.kind === "product" ? [item] : [];
    })
  : [];
const featuredProductIds = new Set(featuredProducts.map(({ id }) => id));
const products = [
  ...featuredProducts,
  ...publishedProducts.filter(({ id }) => !featuredProductIds.has(id)),
];
const headline = homepage?.headline ?? "Гэрийн тавиур.";
const headlineParts = headline.split(" ");
const headlineLead = headlineParts.slice(0, -1).join(" ") || headline;
const headlineAccent = headlineParts.length > 1 ? headlineParts.at(-1) : undefined;
const summary =
  homepage?.summary ??
  shell.identity?.tagline ??
  "Хүнс, цэвэрлэгээ, жижиг бэлгийг нэг тавиураас ойлгомжтой сонгоорой.";
---
<main id="content">
  <section class="pantry" aria-labelledby="pantry-title">
    <div class="pantry-beam">
      <span>Ө48 Өдөр</span><b>Тавиур 01 · өдөр тутмын нөөц</b><span>УБ · 09:00–21:00</span>
    </div>
    <div class="pantry-grid">
      <aside class="pantry-categories" aria-label="Бүтээгдэхүүний ангилал">
        <p>Тасалгаа</p>
        <ol>
          {groupings.categories.length === 0
            ? <li><span>—</span>Ангилал удахгүй нэмэгдэнэ</li>
            : groupings.categories.map((category, index) => <li><span>{String(index + 1).padStart(2, "0")}</span><a href={`/categories/${category.slug}`}>{category.name}</a></li>)}
        </ol>
      </aside>
      <div class="pantry-copy">
        <p class="kicker">Өдөр бүрийн хэрэгцээг цэгцтэй</p>
        <h1 id="pantry-title">{headlineLead}{" "}{headlineAccent && <><br /><span>{headlineAccent}</span></>}</h1>
        <p>{summary}</p>
        <a href="#catalog">Бараа үзэх</a>
      </div>
      <div class="pantry-image">
        {homepage?.hero
          ? <picture><source type="image/avif" srcset={`/media/${homepage.hero.mediaAssetId}/960.avif`} /><img src={`/media/${homepage.hero.mediaAssetId}/960.webp`} alt={homepage.hero.altText} width="960" height="960" fetchpriority="high" /></picture>
          : <img src="/media/hero-pantry.webp" alt="Хүнс, гэр ахуйн бүтээгдэхүүн өрсөн Өрнүүн 48-ын цайвар модон тавиур" width="1000" height="1000" fetchpriority="high" />}
        <div class="shelf-marker" aria-hidden="true"><b>48</b><span>гэрийн нөөц</span></div>
      </div>
      <article class="bundle-bay">
        <img src="/media/b01-cleaning-bundle.webp" alt="Угаалгын нунтаг болон аяга таваг угаагчийн цэвэрлэгээний хослол" width="1000" height="1000" loading="lazy" />
        <p>Тасалгаа 05</p><h2>Цэвэрлэгээний хослол</h2><span>Өдөр тутмын хоёр бараа нэг дор</span>
      </article>
      <div class="delivery-bay">{commerceSettings?.freeDeliveryThresholdMnt == null ? <><span>Хүргэлтийн нөхцөл</span><strong>Үнэгүй хүргэлт тохируулаагүй</strong></> : <><span>{new Intl.NumberFormat("mn-MN").format(commerceSettings.freeDeliveryThresholdMnt)} ₮</span><strong>дээш хүргэлт үнэгүй</strong></>}<small>{commerceSettings?.deliveryEnabled === false ? "Хүргэлт түр хаалттай" : "Улаанбаатар хотод"}</small></div>
    </div>
    <div class="pantry-plinth"><span>01 Хүнс</span><span>02 Гэр ахуй</span><span>03 Жижиг бэлэг</span><b>ӨРНҮҮН / 48</b></div>
  </section>

  <section id="catalog" class="catalog-shelf" aria-labelledby="catalog-title">
    <header class="catalog-shelf__header">
      <div>
        <span>Тавиур 02 · {products.length} бүтээгдэхүүн</span>
        <h2 id="catalog-title">Өдөр тутмын сонголт</h2>
        <p>Үнэ, тайлбар, савлагааг нэг дор харж, хэрэгтэй бараагаа шууд нээгээрэй.</p>
      </div>
      <a href="/search">Каталогоос хайх <span aria-hidden="true">→</span></a>
    </header>
    {groupings.categories.length > 0 && (
      <nav class="catalog-shelf__categories" aria-label="Каталогийн ангилал">
        <a href="#catalog" aria-current="page">Бүх бараа</a>
        {groupings.categories.map((category) => <a href={`/categories/${category.slug}`}>{category.name}</a>)}
      </nav>
    )}
    {products.length === 0
      ? <p class="catalog-shelf__empty">Одоогоор нийтлэгдсэн бүтээгдэхүүн алга.</p>
      : <div class="catalog-grid">{products.map((item, index) => <CatalogProductCard item={item} position={index + 1} priority={index === 0} />)}</div>}
    <div class="catalog-shelf__rail"><span>Үнэ бүхэл төгрөгөөр</span><span>Боломжийг худалдан авах үед шинэчилнэ</span><b>Ө48</b></div>
  </section>

  <section class="customer-auth" aria-labelledby="customer-auth-title">
    <div>
      <h2 id="customer-auth-title">Захиалгын түүхээ хадгалах</h2>
      <p>Утасны дугаараа нэг удаагийн кодоор баталгаажуулбал энэ дэлгүүрийн захиалгуудаа дараа нь харж болно. Худалдан авалт хийхэд нэвтрэх шаардлагагүй.</p>
    </div>
    <CustomerAuthIsland client:only="solid-js" />
  </section>
</main>
