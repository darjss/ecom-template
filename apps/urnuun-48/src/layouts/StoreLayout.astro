---
import { ClientRouter } from "astro:transitions";
import { readCanonicalStoreOrigin } from "@ecom/api";
import "@ecom/ui/styles.css";
import "../styles/tailwind.css";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, readCanonicalStoreOrigin());
---
<!doctype html>
<html lang="mn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#f6f0df" />
    {!noindex && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">Үндсэн агуулга руу очих</a>
    <slot />
  </body>
</html>
