---
import "@ecom/ui/styles.css";
import "../styles/tailwind.css";

interface Props { title: string }
const { title } = Astro.props;
---
<!doctype html>
<html lang="mn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class="min-w-80 bg-stone-100">
    <a
      class="fixed top-4 left-4 z-50 -translate-y-24 rounded-lg bg-(--ink) px-4 py-3 text-(--paper) focus:translate-y-0"
      href="#admin-content">Үндсэн агуулга руу очих</a
    >
    <slot />
  </body>
</html>
