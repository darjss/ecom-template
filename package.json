{
  "name": "ecom-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "pnpm bindings:generate",
    "dev": "pnpm --filter @shops/urnuun-48 dev",
    "build": "pnpm --filter @shops/urnuun-48 build",
    "preview": "pnpm --filter @shops/urnuun-48 preview",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm exec oxlint . && pnpm --filter @shops/urnuun-48 exec eslint \"src/**/*.astro\"",
    "typecheck": "tsc -b --pretty false",
    "astro:check": "pnpm --filter @shops/urnuun-48 exec astro check",
    "knip": "knip",
    "sherif": "sherif -r multiple-dependency-versions",
    "deps:check": "node scripts/check-dependencies.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm astro:check && pnpm knip && pnpm sherif && pnpm deps:check && pnpm build",
    "bindings:generate": "pnpm --filter @shops/urnuun-48 bindings:generate",
    "db:generate": "drizzle-kit generate --config packages/kernel/drizzle.config.ts",
    "db:migrate:local": "pnpm --filter @shops/urnuun-48 db:migrate:local",
    "auth:generate": "better-auth generate --config packages/kernel/scripts/staff-auth.config.ts --output packages/kernel/src/auth/staff.generated.ts --yes && better-auth generate --config packages/kernel/scripts/customer-auth.config.ts --output packages/kernel/src/auth/customer.generated.ts --yes",
    "store:delivery": "tsx packages/delivery/src/cli.ts"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.0.0",
    "drizzle-kit": "0.31.10",
    "knip": "6.27.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "sherif": "1.13.0",
    "tsx": "4.21.0",
    "typescript": "7.0.2",
    "wrangler": "4.107.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.2"
}
