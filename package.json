{
  "name": "ecom-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "pnpm bindings:generate",
    "dev": "pnpm dev:stores",
    "dev:proxy": "portless proxy start",
    "dev:stores": "pnpm dev:proxy && tsx packages/delivery/src/cli.ts dev --store urnuun-48",
    "dev:store": "tsx packages/delivery/src/cli.ts dev",
    "build": "pnpm build:store --store urnuun-48",
    "build:store": "tsx packages/delivery/src/cli.ts build",
    "preview": "tsx packages/delivery/src/cli.ts preview --store urnuun-48",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --threads=1 .",
    "lint:astro": "pnpm --filter @shops/urnuun-48 exec eslint 'src/**/*.astro'",
    "typecheck": "tsc -b --pretty false",
    "astro:check": "pnpm --filter @shops/urnuun-48 exec astro check",
    "knip": "knip",
    "sherif": "sherif -r multiple-dependency-versions",
    "deps:check": "node scripts/check-dependencies.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm lint:astro && pnpm typecheck && pnpm astro:check && pnpm knip && pnpm sherif && pnpm deps:check && pnpm generated:check && pnpm build",
    "bindings:generate": "pnpm --filter @shops/urnuun-48 bindings:generate",
    "db:generate": "drizzle-kit generate --config packages/kernel/drizzle.config.ts",
    "db:migrate:local": "pnpm --filter @shops/urnuun-48 db:migrate:local",
    "reference:seed": "tsx scripts/reference-store/seed.ts",
    "search:migration:generate": "tsx packages/kernel/scripts/catalog-search-migration.ts",
    "auth:generate": "better-auth generate --config packages/kernel/scripts/staff-auth.config.ts --output packages/kernel/src/auth/staff.generated.ts --yes && better-auth generate --config packages/kernel/scripts/customer-auth.config.ts --output packages/kernel/src/auth/customer.generated.ts --yes && oxfmt packages/kernel/src/auth/*.generated.ts",
    "generated:check": "node scripts/check-generated.mjs && tsx packages/kernel/scripts/catalog-search-migration.ts --check",
    "store:delivery": "tsx packages/delivery/src/cli.ts",
    "store:owner:add": "tsx packages/delivery/src/cli.ts owner-add",
    "staff:id:create": "tsx packages/contracts/scripts/create-staff-id.ts",
    "api:request": "NODE_EXTRA_CA_CERTS=$HOME/.portless/ca.pem tsx packages/delivery/src/api-request.ts",
    "audit:id:create": "tsx packages/contracts/scripts/create-audit-event-id.ts",
    "store:create": "tsx packages/delivery/src/cli.ts create",
    "store:apply": "tsx packages/delivery/src/cli.ts apply",
    "store:proof": "tsx packages/delivery/src/cli.ts proof",
    "store:cleanup": "tsx packages/delivery/src/cli.ts cleanup"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@ecom/contracts": "workspace:*",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.0.0",
    "dismatch": "2.6.0",
    "drizzle-kit": "0.31.10",
    "eslint-plugin-solid": "0.14.5",
    "knip": "6.27.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "portless": "0.15.1",
    "sherif": "1.13.0",
    "solid-js": "1.9.13",
    "tsx": "4.21.0",
    "typescript": "7.0.2",
    "valibot": "1.4.2",
    "wrangler": "4.107.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.2"
}
